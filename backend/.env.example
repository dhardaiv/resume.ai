# Hugging Face model ID (e.g. sentence-transformers/all-MiniLM-L6-v2)
EMBEDDING_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2

# Set to 1 after the model has been downloaded once, to avoid network calls on every startup.
# Run `python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('sentence-transformers/all-MiniLM-L6-v2')"` once first.
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# Optional: host/port
# HOST=0.0.0.0
# PORT=8000
